# --- Pick a chat backend (default: groq) ---
# PC_LLM_PROVIDER=groq   # or: gemini

# Groq: free key at https://console.groq.com
GROQ_API_KEY=your_key_here

# Gemini: free key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_key_here

# Optional model overrides:
# PC_GROQ_MODEL=llama-3.3-70b-versatile
# PC_GEMINI_MODEL=gemini-2.0-flash
# PC_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
